# ── Sepolia RPC ────────────────────────────────────────────────────────────
# Get a free Sepolia RPC from Alchemy: https://www.alchemy.com/
# Or Infura: https://www.infura.io/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ── Deployer Wallet ────────────────────────────────────────────────────────
# Private key of the wallet that will deploy the contracts.
# NEVER commit this to git. Add .env to your .gitignore.
# Fund it with Sepolia ETH from: https://sepoliafaucet.com/
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Etherscan Verification ─────────────────────────────────────────────────
# Get an API key from https://etherscan.io/
# Used for: npx hardhat verify --network sepolia <CONTRACT_ADDRESS>
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Deployed Contract Addresses (filled in after deployment) ───────────────
# Copy these from the deployment output and paste here.
# The frontend will read these to know which contracts to call.
NEXT_PUBLIC_CUSDT_ADDRESS=
NEXT_PUBLIC_CETH_ADDRESS=
NEXT_PUBLIC_POOL_ADDRESS=
NEXT_PUBLIC_FAUCET_ADDRESS=

# ── Frontend Chain Config ──────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_CHAIN_NAME=sepolia
